-- Criando a ScreenGui
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui")

-- Criando o Frame principal (UI Quincy)
local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 250, 0, 150)
frame.Position = UDim2.new(0.5, -125, 0.5, -75)
frame.BackgroundColor3 = Color3.fromRGB(10, 20, 40) -- azul escuro
frame.Parent = screenGui

-- UICorner e UIStroke no Frame
local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 12)
corner.Parent = frame

local stroke = Instance.new("UIStroke")
stroke.Thickness = 2
stroke.Color = Color3.fromRGB(255, 215, 0) -- dourado
stroke.Parent = frame

-- Título dourado
local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 40)
title.Position = UDim2.new(0, 0, 0, 0)
title.BackgroundTransparency = 1
title.Text = "Quincy"
title.TextColor3 = Color3.fromRGB(255, 215, 0)
title.TextScaled = true
title.Font = Enum.Font.SourceSansBold
title.Parent = frame

-- Botão de toggle isolado (logo Quincy)
local logoToggle = Instance.new("ImageButton")
logoToggle.Size = UDim2.new(0, 60, 0, 60)
logoToggle.Position = UDim2.new(0, 10, 0, 10) -- canto superior esquerdo da tela
logoToggle.Image = "rbxassetid://91771463650036" -- TextureId correto da logo
logoToggle.Parent = screenGui

local logoCorner = Instance.new("UICorner")
logoCorner.CornerRadius = UDim.new(0, 8)
logoCorner.Parent = logoToggle

local logoStroke = Instance.new("UIStroke")
logoStroke.Thickness = 2
logoStroke.Color = Color3.fromRGB(255, 215, 0)
logoStroke.Parent = logoToggle

-- Função para esconder/mostrar o Frame
local uiVisible = true
logoToggle.MouseButton1Click:Connect(function()
    uiVisible = not uiVisible
    frame.Visible = uiVisible
end)
