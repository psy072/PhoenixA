-- Criando a ScreenGui
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui")

-- Criando um Frame com fundo azul escuro
local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 250, 0, 150)
frame.Position = UDim2.new(0.5, -125, 0.5, -75)
frame.BackgroundColor3 = Color3.fromRGB(10, 20, 40) -- azul bem escuro
frame.Parent = screenGui

-- Criando um título dourado
local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 40)
title.Position = UDim2.new(0, 0, 0, 0)
title.BackgroundTransparency = 1
title.Text = "Quincy"
title.TextColor3 = Color3.fromRGB(255, 215, 0) -- dourado
title.TextScaled = true
title.Font = Enum.Font.SourceSansBold
title.Parent = frame

-- Criando botão de toggle com a logo Quincy
local toggleButton = Instance.new("ImageButton")
toggleButton.Size = UDim2.new(0, 100, 0, 100)
toggleButton.Position = UDim2.new(0.5, -50, 0.5, -30)
toggleButton.Image = "rbxassetid://129084737096368" -- logo Quincy
toggleButton.Parent = frame

-- Estado inicial
local isOn = false

-- Função de toggle
toggleButton.MouseButton1Click:Connect(function()
    isOn = not isOn
    if isOn then
        print("Quincy ligado!")
        toggleButton.ImageColor3 = Color3.fromRGB(255, 215, 0) -- dourado ativo
    else
        print("Quincy desligado!")
        toggleButton.ImageColor3 = Color3.fromRGB(150, 150, 150) -- cinza inativo
    end
end)
